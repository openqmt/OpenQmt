{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "OpenQmt",
    "version": "0.1.0",
    "identifier": "com.openqmt.desktop",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1421",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "OpenQmt",
                "width": 1280,
                "height": 860,
                "minWidth": 100,
                "minHeight": 600,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
