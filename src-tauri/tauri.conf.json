{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "OpenQmt",
    "version": "0.1.0",
    "identifier": "com.openqmt.desktop",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1421",
        "beforeDevCommand": "pnpm run dev",
        "beforeBuildCommand": "pnpm run build"
    },
    "app": {
        "windows": [
            {
                "title": "OpenQmt",
                "width": 1280,
                "height": 860,
                "minWidth": 100,
                "minHeight": 600,
                "visible": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5MkM1RkJCMTM3RjUzRjkKUldUNVUzOFR1MThzcVhoWXRlakxCSWRQRW4zWTY4cXk3Zm05SkF0NnNXMlduVkk4bnV3ZWpOdkMK",
            "endpoints": [
                "https://github.com/user/repo/releases/latest/download/latest.json"
            ]
        }
    }
}
